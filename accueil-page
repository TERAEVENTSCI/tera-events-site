<script>
var _n=document.getElementById('nav');
if(_n) window.addEventListener('scroll',function(){_n.classList.toggle('scrolled',window.scrollY>60);});

function hbgToggle(){
  var btn=document.getElementById('hbg-btn');
  var menu=document.getElementById('hbg-menu');
  if(!btn||!menu) return;
  var isOpen=!menu.classList.contains('open');
  if(isOpen){menu.classList.add('open');btn.classList.add('open');document.body.style.overflow='hidden';}
  else{menu.classList.remove('open');btn.classList.remove('open');document.body.style.overflow='';}
}
function hbgClose(){
  var btn=document.getElementById('hbg-btn');
  var menu=document.getElementById('hbg-menu');
  if(btn)btn.classList.remove('open');
  if(menu)menu.classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',function(e){if(e.key==='Escape')hbgClose();});

document.body.classList.add('js-ready');
function activateReveals(){
  var els=document.querySelectorAll('.reveal');
  els.forEach(function(el){var r=el.getBoundingClientRect();if(r.top<window.innerHeight+120)el.classList.add('in');});
  if(window.IntersectionObserver){
    var ro=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('in');});},{threshold:0,rootMargin:'80px'});
    els.forEach(function(el){ro.observe(el);});
  }
  setTimeout(function(){els.forEach(function(el){el.classList.add('in');});},800);
}
if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',activateReveals);}else{activateReveals();}
</script>


<script>
// Popup Salle Tera
function closePopup(){
  var o=document.getElementById('popup-overlay');
  if(o){o.classList.remove('visible');sessionStorage.setItem('popup_seen','1');}
}
document.addEventListener('keydown',function(e){if(e.key==='Escape')closePopup();});
if(!sessionStorage.getItem('popup_seen')){
  setTimeout(function(){
    var o=document.getElementById('popup-overlay');
    if(o) o.classList.add('visible');
  },3000);
}
</script>
