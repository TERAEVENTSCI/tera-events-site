<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tera events — Agence d'Event Planning à Abidjan | Corporate & Privé</title>
<meta name="description" content="Tera events, agence d'event planning à Abidjan. Événements corporate et privés dans notre espace ou dans le lieu de votre choix.">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>/* TERA EVENTS — Design System v2
   Palette extraite du logo :
   Bleu marine  #152060
   Or champagne #C4916E
   Blanc        #FFFFFF
*/
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  /* Bleus */
  --b1:#0E1847;        /* très profond */
  --b2:#152060;        /* bleu logo principal */
  --b3:#1C2B78;        /* légèrement plus clair */
  --b4:#253490;        /* hover / accent */
  --b-pale:#EEF0F8;    /* fond sections claires */
  --b-tint:#DDE1F3;    /* bordures douces côté bleu */

  /* Or */
  --or:#C4916E;        /* rose-or du logo */
  --or2:#D9AF93;       /* or clair hover */
  --or3:#EDD5C2;       /* or très pâle */
  --or4:#8B5E3C;       /* or foncé */

  /* Blanc / neutres */
  --blanc:#FFFFFF;
  --off:#FAFAF8;
  --gris:#6B7080;
  --gris2:#9CA4B0;

  /* Borders */
  --bor-or:rgba(196,145,110,0.25);
  --bor-or-h:rgba(196,145,110,0.55);
  --bor-b:rgba(255,255,255,0.12);
  --bor-b-h:rgba(255,255,255,0.25);

  --r:2px; --r2:6px; --r3:12px;
  --t:0.30s cubic-bezier(.4,0,.2,1);
  --shadow:0 20px 60px rgba(14,24,71,0.18);
}

html{scroll-behavior:smooth}
body{background:var(--blanc);color:var(--b2);font-family:'DM Sans',sans-serif;font-weight:300;font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Cormorant Garamond',serif;font-weight:400;line-height:1.1;color:var(--b2)}
a{text-decoration:none}
img{display:block;max-width:100%}

.container{max-width:1180px;margin:0 auto;padding:0 clamp(1.5rem,5vw,3.5rem)}
section{padding:clamp(4rem,8vw,8rem) 0}

/* Typographie */
.eyebrow{font-family:'DM Sans',sans-serif;font-size:0.65rem;font-weight:500;letter-spacing:0.26em;text-transform:uppercase;color:var(--or);display:block;margin-bottom:0.9rem}
.eyebrow-w{font-family:'DM Sans',sans-serif;font-size:0.65rem;font-weight:500;letter-spacing:0.26em;text-transform:uppercase;color:var(--or3);display:block;margin-bottom:0.9rem}

/* Boutons */
.btn{display:inline-flex;align-items:center;gap:0.55rem;font-family:'DM Sans',sans-serif;font-size:0.72rem;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;padding:0.9rem 2rem;border-radius:var(--r);transition:all var(--t);cursor:pointer;border:1px solid transparent;white-space:nowrap}
.btn-or{background:var(--or);color:var(--blanc);border-color:var(--or)}
.btn-or:hover{background:var(--or2);border-color:var(--or2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(196,145,110,0.35)}
.btn-bleu{background:var(--b2);color:var(--blanc);border-color:var(--b2)}
.btn-bleu:hover{background:var(--b3);border-color:var(--b3);transform:translateY(-2px)}
.btn-outline-w{background:transparent;color:var(--blanc);border-color:rgba(255,255,255,0.45)}
.btn-outline-w:hover{border-color:var(--or);color:var(--or3)}
.btn-outline-b{background:transparent;color:var(--b2);border-color:var(--bor-or-h)}
.btn-outline-b:hover{border-color:var(--or);color:var(--or4)}
.btn-ghost{background:transparent;color:var(--or);border:none;padding-left:0;padding-right:0;gap:0.5rem}
.btn-ghost:hover{color:var(--or2);gap:0.9rem}

/* === NAVIGATION === */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:1.2rem clamp(1.5rem,5vw,3.5rem);display:flex;align-items:center;justify-content:space-between;transition:all var(--t);background:rgba(14,24,71,0.88);backdrop-filter:blur(12px)}
.nav.scrolled{background:rgba(14,24,71,0.97);backdrop-filter:blur(20px);padding:0.8rem clamp(1.5rem,5vw,3.5rem);border-bottom:1px solid var(--bor-b)}
.nav-logo{display:flex;align-items:center;text-decoration:none;flex-shrink:0}
.nav-logo-img{height:50px;width:auto;display:block}
.nav.scrolled .nav-logo-img{height:42px}
.nav-links{display:flex;align-items:center;gap:1.8rem;list-style:none;margin:0;padding:0}
.nav-links a{font-size:0.7rem;font-weight:400;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.78);transition:color var(--t);white-space:nowrap}
.nav-links a:hover,.nav-links a.active{color:var(--blanc)}
.nav-toggle{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px}
.nav-toggle span{width:22px;height:1px;background:var(--blanc);display:block;transition:all .3s ease}
.nav.open .nav-toggle span:nth-child(1){transform:translateY(6px) rotate(45deg)}
.nav.open .nav-toggle span:nth-child(2){opacity:0;transform:scaleX(0)}
.nav.open .nav-toggle span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}
@media(max-width:960px){
  .nav-links{display:none;flex-direction:column;position:fixed;inset:0;background:var(--b1);justify-content:center;align-items:center;gap:2.5rem;z-index:150;padding:2rem}
  .nav-toggle{display:flex}
  .nav.open .nav-links{display:flex}
  .nav.open .nav-links a{font-size:1.1rem;color:rgba(255,255,255,0.8)}
  .nav.open .nav-links .btn{display:inline-flex;margin-top:0.5rem}
}

/* Sections */
.section-bleu{background:var(--b2);color:var(--blanc)}
.section-bleu h1,.section-bleu h2,.section-bleu h3,.section-bleu h4{color:var(--blanc)}
.section-dark{background:var(--b1);color:var(--blanc)}
.section-dark h1,.section-dark h2,.section-dark h3,.section-dark h4{color:var(--blanc)}
.section-pale{background:var(--b-pale)}
.section-off{background:var(--off)}

/* Cards */
.card-w{background:var(--blanc);border:1px solid var(--bor-or);border-radius:var(--r3);padding:2rem;transition:border-color var(--t),transform var(--t),box-shadow var(--t)}
.card-w:hover{border-color:var(--bor-or-h);transform:translateY(-4px);box-shadow:var(--shadow)}
.card-b{background:rgba(255,255,255,0.07);border:1px solid var(--bor-b);border-radius:var(--r3);padding:2rem;transition:border-color var(--t),background var(--t)}
.card-b:hover{background:rgba(255,255,255,0.11);border-color:var(--bor-b-h)}

/* Ligne or décorative */
.or-line{width:36px;height:1px;background:var(--or);display:inline-block;vertical-align:middle;margin-right:0.8rem}

/* Dividers */
.div-or{border:none;height:1px;background:var(--bor-or);margin:2.5rem 0}
.div-bw{border:none;height:1px;background:var(--bor-b)}

/* Reveal */
.reveal{opacity:1;transform:none}
.js-ready .reveal{opacity:0;transform:translateY(20px);transition:opacity 0.65s ease,transform 0.65s ease}
.js-ready .reveal.in{opacity:1;transform:none}
.js-ready .d1{transition-delay:0.1s}.js-ready .d2{transition-delay:0.2s}.js-ready .d3{transition-delay:0.3s}.js-ready .d4{transition-delay:0.4s}

/* Footer */
footer{background:var(--b1);color:rgba(255,255,255,0.7);padding:4.5rem 0 2rem}
.footer-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:3rem;padding-bottom:3rem;border-bottom:1px solid var(--bor-b);margin-bottom:2rem}
.footer-logo-name{display:none}
.footer-logo-tag{font-size:0.58rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--or);display:block;margin-bottom:1.2rem}
.footer-desc{font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;color:rgba(255,255,255,0.55)}
.footer-socials{display:flex;gap:0.65rem}
.footer-socials a{width:32px;height:32px;border:1px solid var(--bor-b);border-radius:var(--r);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.55);transition:all var(--t)}
.footer-socials a:hover{border-color:var(--or);color:var(--or)}
.footer-col-title{font-size:0.62rem;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:var(--or);margin-bottom:1.1rem;display:block}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:0.55rem}
.footer-links a{font-size:0.82rem;color:rgba(255,255,255,0.5);transition:color var(--t)}
.footer-links a:hover{color:var(--blanc)}
.footer-ci{display:flex;gap:0.65rem;align-items:flex-start;margin-bottom:0.65rem}
.footer-ci-text{font-size:0.8rem;color:rgba(255,255,255,0.5);line-height:1.55}
.footer-ci-text a{color:rgba(255,255,255,0.5)}
.footer-ci-text a:hover{color:var(--or)}
.footer-bottom{display:flex;justify-content:space-between;flex-wrap:wrap;gap:0.75rem}
.footer-bottom p,.footer-bottom a{font-size:0.72rem;color:rgba(255,255,255,0.35);text-decoration:none}
.footer-bottom a:hover{color:var(--or)}
@media(max-width:900px){.footer-grid{grid-template-columns:1fr 1fr;gap:2rem}}
@media(max-width:550px){.footer-grid{grid-template-columns:1fr}}

/* Hero */
.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding-bottom:clamp(4rem,8vh,6rem);background:var(--b2);overflow:hidden}
.hero-bg{position:absolute;inset:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;opacity:0.60;mix-blend-mode:luminosity}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(155deg,rgba(14,24,71,0.25) 0%,rgba(21,32,96,0.50) 55%,var(--b1) 100%)}
.hero-deco{position:absolute;top:-100px;right:-100px;width:600px;height:600px;border-radius:50%;border:1px solid rgba(196,145,110,0.10);pointer-events:none}
.hero-deco2{position:absolute;top:-50px;right:-50px;width:450px;height:450px;border-radius:50%;border:1px solid rgba(196,145,110,0.07);pointer-events:none}
.hero-content{position:relative;z-index:2;width:100%}
.hero-pill{display:inline-flex;align-items:center;gap:0.6rem;border:1px solid var(--bor-b);background:rgba(255,255,255,0.05);padding:0.38rem 1.1rem;border-radius:40px;margin-bottom:2rem;font-size:0.65rem;font-weight:400;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.7)}
.hero-pill-dot{width:5px;height:5px;background:var(--or);border-radius:50%}
.hero h1{font-size:clamp(3rem,7.5vw,7rem);font-weight:300;letter-spacing:-0.03em;line-height:0.97;color:var(--blanc);margin-bottom:0.15em}
.hero h1 em{font-style:italic;color:var(--or3)}
.hero-sub{font-size:clamp(0.95rem,1.6vw,1.12rem);color:rgba(255,255,255,0.68);line-height:1.7;max-width:520px;margin:1.4rem 0 2.4rem}
.hero-sub strong{color:var(--blanc)}
.hero-ctas{display:flex;flex-wrap:wrap;gap:0.9rem;margin-bottom:3.5rem}
.hero-stats{border-top:1px solid var(--bor-b);padding-top:2rem;display:flex;gap:3rem;flex-wrap:wrap}
.hstat-n{font-family:'Cormorant Garamond',serif;font-size:2.6rem;font-weight:300;color:var(--blanc);line-height:1;display:block}
.hstat-n span{color:var(--or)}
.hstat-l{font-size:0.65rem;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.45)}
.hero-scroll-ind{position:absolute;right:clamp(1.5rem,5vw,3.5rem);bottom:2rem;z-index:2;display:flex;flex-direction:column;align-items:center;gap:6px}
.hero-scroll-ind span{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.35);writing-mode:vertical-lr}
.scroll-line{width:1px;height:45px;background:linear-gradient(to bottom,var(--or),transparent);animation:sl 2s ease-in-out infinite}
@keyframes sl{0%,100%{opacity:1}50%{opacity:0.3}}

/* Dual offer strip */
.duo{display:grid;grid-template-columns:1fr 1fr}
.duo-col{padding:clamp(3rem,6vw,5rem);display:flex;flex-direction:column;gap:1.5rem;position:relative;transition:background var(--t)}
.duo-col:first-child{background:var(--blanc);border-right:1px solid var(--bor-or)}
.duo-col:last-child{background:var(--b-pale)}
.duo-col:hover{background:var(--or3)}
.duo-num{font-family:'Cormorant Garamond',serif;font-size:4rem;font-weight:300;color:var(--bor-or);line-height:1;position:absolute;top:1.5rem;right:2rem}
.duo-icon{width:44px;height:44px;border:1px solid var(--bor-or);border-radius:var(--r);display:flex;align-items:center;justify-content:center}
.duo-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:400;color:var(--b2);line-height:1.15}
.duo-desc{font-size:0.88rem;color:var(--gris);line-height:1.72;flex:1}
.duo-note{font-size:0.75rem;color:var(--b4);font-weight:500;letter-spacing:0.04em}
@media(max-width:640px){.duo{grid-template-columns:1fr}.duo-col:first-child{border-right:none;border-bottom:1px solid var(--bor-or)}}

/* Singularité */
.singu{display:grid;grid-template-columns:1fr 1.1fr;gap:0;border:1px solid var(--bor-or);border-radius:var(--r3);overflow:hidden;margin-top:clamp(3rem,6vw,6rem)}
.singu-text{padding:clamp(2.5rem,5vw,4rem);border-right:1px solid var(--bor-or)}
.singu-visual{position:relative;min-height:400px;overflow:hidden}
.singu-visual img{width:100%;height:100%;object-fit:cover;opacity:0.85;transition:opacity var(--t);display:block}
.singu-visual:hover img{opacity:1}
.singu-list{list-style:none;margin-top:1.8rem;display:flex;flex-direction:column;gap:0.85rem}
.singu-list li{display:flex;gap:0.9rem;align-items:flex-start;font-size:0.88rem;color:var(--gris);line-height:1.6}
.singu-list li::before{content:'';width:5px;height:5px;background:var(--or);border-radius:50%;flex-shrink:0;margin-top:7px}
@media(max-width:760px){.singu{grid-template-columns:1fr}.singu-text{border-right:none;border-bottom:1px solid var(--bor-or)}.singu-visual{min-height:280px}}

/* Services */
.svcs{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--bor-or);border-radius:var(--r3);overflow:hidden}
.svc{padding:2rem 1.75rem;border-right:1px solid var(--bor-or);background:var(--blanc);transition:background var(--t)}
.svc:last-child{border-right:none}
.svc:hover{background:var(--b-pale)}
.svc svg{opacity:0.6;margin-bottom:1.1rem}
.svc h4{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--b2);margin-bottom:0.5rem}
.svc p{font-size:0.8rem;color:var(--gris);line-height:1.6}
@media(max-width:900px){.svcs{grid-template-columns:1fr 1fr}.svc{border-right:none;border-bottom:1px solid var(--bor-or)}.svc:nth-child(odd){border-right:1px solid var(--bor-or)}}
@media(max-width:480px){.svcs{grid-template-columns:1fr}.svc{border-right:none}}

/* Clients */
.clients-belt{border-top:1px solid var(--bor-or);border-bottom:1px solid var(--bor-or);padding:1.6rem 0;overflow:hidden}
.clients-track{display:flex;gap:3rem;align-items:center;animation:mq 22s linear infinite;width:max-content}
.clients-belt:hover .clients-track{animation-play-state:paused}
@keyframes mq{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.clogo{font-family:'Cormorant Garamond',serif;font-size:0.8rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:var(--gris2);padding:0.45rem 1.3rem;border:1px solid var(--bor-or);white-space:nowrap;transition:all var(--t)}
.clogo:hover{color:var(--or4);border-color:var(--bor-or-h)}

/* Testimonials */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.testi{background:var(--blanc);border:1px solid var(--bor-or);border-radius:var(--r3);padding:2rem;position:relative}
.testi::before{content:'"';font-family:'Cormorant Garamond',serif;font-size:5.5rem;font-weight:300;color:var(--or);opacity:0.15;position:absolute;top:-4px;left:1.5rem;line-height:1}
.testi-cat{font-size:0.62rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:var(--or);margin-bottom:0.9rem;display:block}
.testi-txt{font-size:0.88rem;color:var(--gris);line-height:1.7;font-style:italic;position:relative;z-index:1;margin-bottom:1.4rem}
.testi-auth strong{display:block;font-size:0.85rem;font-weight:500;color:var(--b2)}
.testi-auth span{font-size:0.76rem;color:var(--gris2)}
@media(max-width:760px){.testi-grid{grid-template-columns:1fr}}

/* CTA Banner */
.cta-band{background:var(--b2);border-radius:var(--r3);padding:clamp(3rem,6vw,5rem);text-align:center;position:relative;overflow:hidden}
.cta-band::before{content:'';position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:400px;height:400px;background:radial-gradient(circle,rgba(196,145,110,0.10) 0%,transparent 65%);pointer-events:none}
.cta-band h2{color:var(--blanc);font-size:clamp(2rem,4vw,3.5rem)}
.cta-band p{color:rgba(255,255,255,0.65);max-width:500px;margin:1rem auto 0;line-height:1.72}
.cta-band-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2.5rem}

/* ══ HAMBURGER MOBILE ══════════════════════════════════════════ */
@media(max-width:960px){.nav-links{display:none !important}.nav-toggle{display:none !important}}
#hbg-btn{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;z-index:9999;position:relative}
#hbg-btn span{display:block;width:25px;height:2px;background:#fff;border-radius:2px;transition:all .3s ease}
@media(max-width:960px){#hbg-btn{display:flex}}
#hbg-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
#hbg-btn.open span:nth-child(2){opacity:0;transform:scaleX(0)}
#hbg-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
#hbg-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:#0E1847;z-index:9998;flex-direction:column;padding-top:72px;overflow-y:auto}
#hbg-menu.open{display:flex !important}
#hbg-menu a{display:block;padding:1rem 2rem;color:rgba(255,255,255,.8);font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.08);transition:background .2s,color .2s}
#hbg-menu a:first-child{border-top:1px solid rgba(255,255,255,.08)}
#hbg-menu a:hover{color:#C4916E;background:rgba(255,255,255,.04)}
#hbg-menu .hbg-cta{margin:1.5rem 2rem;padding:.9rem;background:#C4916E;color:#fff !important;text-align:center;border-radius:2px;border:none !important}
#hbg-menu .hbg-cta:hover{background:#D9AF93 !important}
#hbg-close{position:absolute;top:1rem;right:1.5rem;background:none;border:none;color:rgba(255,255,255,.7);font-size:1.6rem;cursor:pointer;z-index:9999;line-height:1;padding:4px 8px}
/* ══════════════════════════════════════════════════════════════ */




/* ══ POPUP SALLE TERA ══════════════════════════════════════════ */
#popup-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(14,24,71,0.82);
  backdrop-filter:blur(6px);
  z-index:99999;
  align-items:center;justify-content:center;
  padding:1.5rem;
}
#popup-overlay.visible{display:flex}
#popup-box{
  position:relative;
  width:100%;max-width:420px;
  background:#0E1847;
  border:1px solid rgba(196,145,110,0.4);
  border-radius:12px;
  overflow:hidden;
  box-shadow:0 40px 100px rgba(0,0,0,0.6);
  animation:popIn .45s cubic-bezier(.34,1.56,.64,1) both;
  text-align:center;
}
@keyframes popIn{
  from{opacity:0;transform:scale(.88) translateY(24px)}
  to{opacity:1;transform:scale(1) translateY(0)}
}
#popup-close{
  position:absolute;top:.85rem;right:.85rem;
  width:30px;height:30px;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.18);
  border-radius:50%;
  color:rgba(255,255,255,0.7);
  font-size:.9rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;line-height:1;
}
